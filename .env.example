# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/taskflow"

# NextAuth
AUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
AUTH_GOOGLE_ID="your-google-oauth-client-id"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google Generative AI (Gemini) - supports multiple keys for rotation
# Use GEMINI_API_KEYS for multiple keys (comma-separated), or GEMINI_API_KEY for single
GEMINI_API_KEYS="key1,key2,key3"
# GEMINI_API_KEY="single-key"  ← alternative single key

# Internal webhook secret (shared between Baileys server + API routes)
INTERNAL_WEBHOOK_SECRET="generate-a-random-secret"

# WhatsApp sessions storage path
WA_SESSIONS_PATH="./.wa-sessions"

# App URL (used internally for webhooks)
APP_URL="http://localhost:3000"
